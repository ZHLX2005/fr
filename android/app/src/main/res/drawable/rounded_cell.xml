<?xml version="1.0" encoding="utf-8"?>
<!--
  课程单元格圆角形状（白底 + 6dp 圆角）
  ───────────────────
  - 仅描述"圆角"形状，颜色由 Kotlin 端用 setColorFilter 动态染色：
      * 有课 → 课程色
      * 无课 → COLOR_EMPTY（灰）
      * 今天列无课 → COLOR_TODAY_COL_BG（极浅蓝灰）
  - 1dp layout_margin 在 cell style 里，配合这个圆角 = 圆角方块网格
  - 单独抽出来是为了：
      a) RemoteViews 只能引用资源，不能用代码改 drawable 形状
      b) styles.xml 只能引一个 background 资源
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FFFFFF" />
    <corners android:radius="6dp" />
</shape>
