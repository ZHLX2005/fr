<?xml version="1.0" encoding="utf-8"?>
<!--
  课表桌面小组件布局
  ───────────────────
  - 首标列 weight=0.4，占 0.4/7.4 ≈ 5.4%（仅够显示单个数字）
  - 课程列 weight=1 × 7 = 7，占 7/7.4 ≈ 94.6%
  - 行高等高：所有数据行 layout_weight="3"
  - 课程单元格两行排版：课程名 + 地点（styles.xml 中 maxLines=2, autoSize 7~12sp）
  - 节数 / 星期 标签 textSize = 11sp
  - 主标题 textSize = 14sp
  - 单元格 layout_margin = 1dp（格子间隙）
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/timetable_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <!-- 标题（居中 + 上下 padding） -->
    <TextView
        android:id="@+id/timetable_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="课程表"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:paddingVertical="12dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="刷新课程表" />

    <!-- 网格容器：1 行表头 + 5 行数据 -->
    <LinearLayout
        android:id="@+id/timetable_grid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="2dp"
        android:paddingBottom="2dp">

        <!-- ── 表头：1 列节数占位 + 7 列星期 ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:weightSum="7.4">

            <TextView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:gravity="center"
                android:text="" />

            <TextView
                android:id="@+id/day_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="一"
                android:textColor="#666666"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/day_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="二"
                android:textColor="#666666"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/day_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="三"
                android:textColor="#666666"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/day_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="四"
                android:textColor="#666666"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/day_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="五"
                android:textColor="#666666"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/day_5"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="六"
                android:textColor="#666666"
                android:textSize="11sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/day_6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="日"
                android:textColor="#666666"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- ── 数据行模板（5 行重复）── -->
        <!-- Row 0: Slot 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:orientation="horizontal"
            android:weightSum="7.4">

            <TextView
                android:id="@+id/slot_0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:gravity="center"
                android:text="1"
                android:textColor="#374151"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cell_0_0"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_0_1"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_0_2"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_0_3"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_0_4"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_0_5"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_0_6"
                style="@style/TimetableCell" />
        </LinearLayout>

        <!-- Row 1: Slot 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:orientation="horizontal"
            android:weightSum="7.4">

            <TextView
                android:id="@+id/slot_1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:gravity="center"
                android:text="2"
                android:textColor="#374151"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cell_1_0"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_1_1"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_1_2"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_1_3"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_1_4"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_1_5"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_1_6"
                style="@style/TimetableCell" />
        </LinearLayout>

        <!-- Row 2: Slot 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:orientation="horizontal"
            android:weightSum="7.4">

            <TextView
                android:id="@+id/slot_2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:gravity="center"
                android:text="3"
                android:textColor="#374151"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cell_2_0"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_2_1"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_2_2"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_2_3"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_2_4"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_2_5"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_2_6"
                style="@style/TimetableCell" />
        </LinearLayout>

        <!-- Row 3: Slot 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:orientation="horizontal"
            android:weightSum="7.4">

            <TextView
                android:id="@+id/slot_3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:gravity="center"
                android:text="4"
                android:textColor="#374151"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cell_3_0"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_3_1"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_3_2"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_3_3"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_3_4"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_3_5"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_3_6"
                style="@style/TimetableCell" />
        </LinearLayout>

        <!-- Row 4: Slot 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:orientation="horizontal"
            android:weightSum="7.4">

            <TextView
                android:id="@+id/slot_4"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.4"
                android:gravity="center"
                android:text="5"
                android:textColor="#374151"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cell_4_0"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_4_1"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_4_2"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_4_3"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_4_4"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_4_5"
                style="@style/TimetableCell" />
            <TextView
                android:id="@+id/cell_4_6"
                style="@style/TimetableCell" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
